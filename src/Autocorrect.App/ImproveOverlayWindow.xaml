<Window x:Class="Autocorrect.App.ImproveOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="108"
        Height="34"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        AllowsTransparency="True"
        Background="Transparent">
    <Button Content="Improve"
            Click="Improve_OnClick"
            Padding="12,0"
            FontWeight="SemiBold"
            Background="#111827"
            Foreground="White"
            BorderBrush="#111827" />
</Window>
