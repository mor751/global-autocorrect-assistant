<Window x:Class="Autocorrect.App.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Token Compression Dashboard"
        Width="760"
        Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#070B0F"
        FontFamily="Segoe UI">
    <Window.Resources>
        <DropShadowEffect x:Key="CardGlow" Color="#22D3EE" BlurRadius="18" ShadowDepth="0" Opacity="0.25" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0C141B" />
            <Setter Property="BorderBrush" Value="#15303A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="Effect" Value="{StaticResource CardGlow}" />
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64829A" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#67E8F9" />
            <Setter Property="FontSize" Value="34" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style x:Key="MetricUnit" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#3F5566" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="#E5F9FF" />
            <Setter Property="Background" Value="#0E2630" />
            <Setter Property="BorderBrush" Value="#22D3EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Ellipse Width="14" Height="14" Fill="#22D3EE" VerticalAlignment="Center" Effect="{StaticResource CardGlow}" />
            <TextBlock Text="Token Compression Dashboard"
                       Foreground="#E5F9FF"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Grid.Row="1"
                   Text="How many tokens your AI pet saved by optimizing and compressing prompts."
                   Foreground="#5A7488"
                   FontSize="13"
                   Margin="26,6,0,18" />

        <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,18">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="PROMPTS OPTIMIZED" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="PromptsValue" Text="0" Style="{StaticResource MetricValue}" />
                    <TextBlock Text="total rewrites" Style="{StaticResource MetricUnit}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="TOKENS SAVED" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="TokensSavedValue" Text="0" Style="{StaticResource MetricValue}" Foreground="#34D399" />
                    <TextBlock Text="estimated (~4 chars/token)" Style="{StaticResource MetricUnit}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="AVG REDUCTION" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="AvgReductionValue" Text="0%" Style="{StaticResource MetricValue}" />
                    <TextBlock Text="per prompt" Style="{StaticResource MetricUnit}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="TOKENS IN / OUT" Style="{StaticResource MetricLabel}" />
                    <TextBlock x:Name="InOutValue" Text="0 / 0" Style="{StaticResource MetricValue}" FontSize="26" />
                    <TextBlock Text="before / after" Style="{StaticResource MetricUnit}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="RECENT ACTIVITY" Style="{StaticResource MetricLabel}" Margin="0,0,0,10" />
                <Grid Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="RecentList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0A1118" CornerRadius="9" Padding="12,9" Margin="0,0,0,7">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Action}" Foreground="#CDEBF5" FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding When}" Foreground="#4A6173" FontSize="11" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Flow}"
                                                       Foreground="#7FA3B8"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,16,0" />
                                            <Border Grid.Column="2"
                                                    Background="#0E2A22"
                                                    CornerRadius="7"
                                                    Padding="9,4"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Saved}" Foreground="#34D399" FontSize="12" FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock x:Name="EmptyHint"
                               Text="No prompts optimized yet. Put your cursor in any prompt box and press Ctrl+Alt+O, or click the AI pet."
                               Foreground="#3F5566"
                               FontSize="13"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Refresh" Style="{StaticResource ActionButton}" Click="Refresh_OnClick" Margin="0,0,10,0" />
            <Button Content="Reset stats" Style="{StaticResource ActionButton}" Click="Reset_OnClick"
                    Background="#2A0E12" BorderBrush="#F87171" />
        </StackPanel>
    </Grid>
</Window>
