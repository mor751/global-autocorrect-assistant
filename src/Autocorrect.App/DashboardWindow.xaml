<Window x:Class="Autocorrect.App.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Woody - RAG Dashboard"
        Width="1320"
        Height="840"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F14"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#0B0F14" />
        <SolidColorBrush x:Key="Sidebar" Color="#101720" />
        <SolidColorBrush x:Key="Panel" Color="#121922" />
        <SolidColorBrush x:Key="Panel2" Color="#0F151D" />
        <SolidColorBrush x:Key="Line" Color="#26313E" />
        <SolidColorBrush x:Key="Ink" Color="#F3F7FB" />
        <SolidColorBrush x:Key="Muted" Color="#93A1B3" />
        <SolidColorBrush x:Key="Blue" Color="#5B8DFF" />
        <SolidColorBrush x:Key="Green" Color="#58D26B" />
        <SolidColorBrush x:Key="Warn" Color="#F7C948" />
        <SolidColorBrush x:Key="Red" Color="#F87171" />

        <DropShadowEffect x:Key="SoftShadow" Color="#000000" BlurRadius="24" ShadowDepth="0" Opacity="0.35" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="12,3" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="#CAD3DF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#172233" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#3167D8" />
            <Setter Property="BorderBrush" Value="#5788FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
            <Setter Property="Background" Value="#151D28" />
            <Setter Property="BorderBrush" Value="#2E3B4D" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
            <Setter Property="Background" Value="#0E141C" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="CaretBrush" Value="#70A0FF" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource Sidebar}" BorderBrush="#26313E" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="22,28,18,24">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="48" Height="48" CornerRadius="14" Background="#1B2531" BorderBrush="#344155" BorderThickness="1">
                            <TextBlock Text="W" Foreground="#F8D9A8" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,3,0,0">
                            <TextBlock Text="Woody" Foreground="{StaticResource Ink}" FontSize="24" FontWeight="Bold" />
                            <TextBlock Text="Your AI Knowledge Engineer" Foreground="{StaticResource Muted}" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="DashboardNav" Style="{StaticResource NavButton}" Content="Dashboard" Click="DashboardNav_OnClick" />
                    <Button x:Name="BrainNav" Style="{StaticResource NavButton}" Content="View RAG" Click="BrainNav_OnClick" />
                    <Button x:Name="VectorNav" Style="{StaticResource NavButton}" Content="Vector DB &amp; Retrieval" Click="VectorNav_OnClick" />
                    <Button x:Name="HistoryNav" Style="{StaticResource NavButton}" Content="Prompt History" Click="HistoryNav_OnClick" />
                    <Button x:Name="ProjectsNav" Style="{StaticResource NavButton}" Content="Projects" Click="ProjectsNav_OnClick" />
                    <Button x:Name="SettingsNav" Style="{StaticResource NavButton}" Content="Settings" Click="SettingsNav_OnClick" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="16,0,16,20">
                    <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="18" Background="#345BB7">
                                <TextBlock Text="W" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Woody User" Foreground="{StaticResource Ink}" FontWeight="SemiBold" />
                                <TextBlock Text="Local Workspace" Foreground="{StaticResource Muted}" FontSize="12" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="v1.3.0" Foreground="{StaticResource Muted}" FontSize="12" Margin="2,0,0,8" />
                    <TextBlock x:Name="SidebarStatusText" Text="System status loading..." Foreground="{StaticResource Green}" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource Bg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="92" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="28,0,28,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderTitle" Text="RAG Dashboard" Foreground="{StaticResource Ink}" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock x:Name="HeaderSubtitle" Text="Monitor your Retrieval-Augmented Generation pipeline and knowledge brain." Foreground="{StaticResource Muted}" FontSize="13" Margin="0,6,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Refresh" Style="{StaticResource SecondaryButton}" Click="Refresh_OnClick" Margin="0,0,10,0" />
                    <Button Content="..." Style="{StaticResource SecondaryButton}" Width="44" Padding="0" />
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="28,0,28,28">
                    <Grid x:Name="DashboardPage">
                        <StackPanel>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Selected Project" Style="{StaticResource Label}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock x:Name="ProjectNameText" Text="No project selected" Foreground="{StaticResource Ink}" FontSize="18" FontWeight="SemiBold" />
                                            <Border x:Name="ProjectStatusChip" Background="#1C3A26" CornerRadius="10" Padding="9,3" Margin="12,1,0,0">
                                                <TextBlock x:Name="ProjectStatusChipText" Text="No Folder" Foreground="{StaticResource Green}" FontSize="12" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="Path" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,12,0,2" />
                                        <TextBlock x:Name="ProjectPathText" Text="No project selected" Foreground="#D5DDE7" FontSize="13" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Open Project" Style="{StaticResource SecondaryButton}" Click="ChooseFolder_OnClick" VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <UniformGrid Columns="6" Margin="0,0,0,14">
                                <Border Style="{StaticResource Card}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Quick Brain" Foreground="{StaticResource Ink}" FontWeight="SemiBold" /><TextBlock x:Name="QuickBrainStatusText" Text="No folder" Foreground="{StaticResource Muted}" Margin="0,6,0,0" /></StackPanel></Border>
                                <Border Style="{StaticResource Card}" Margin="8,0"><StackPanel><TextBlock Text="Semantic RAG" Foreground="{StaticResource Ink}" FontWeight="SemiBold" /><TextBlock x:Name="SemanticStatusText" Text="No brain" Foreground="{StaticResource Muted}" Margin="0,6,0,0" /></StackPanel></Border>
                                <Border Style="{StaticResource Card}" Margin="8,0"><StackPanel><TextBlock Text="Deep Brain" Foreground="{StaticResource Ink}" FontWeight="SemiBold" /><TextBlock x:Name="DeepBrainStatusText" Text="Pending" Foreground="{StaticResource Muted}" Margin="0,6,0,0" /></StackPanel></Border>
                                <Border Style="{StaticResource Card}" Margin="8,0"><StackPanel><TextBlock Text="Qdrant" Foreground="{StaticResource Ink}" FontWeight="SemiBold" /><TextBlock x:Name="QdrantStatusText" Text="Checking" Foreground="{StaticResource Muted}" Margin="0,6,0,0" /></StackPanel></Border>
                                <Border Style="{StaticResource Card}" Margin="8,0"><StackPanel><TextBlock Text="FastEmbed" Foreground="{StaticResource Ink}" FontWeight="SemiBold" /><TextBlock x:Name="FastEmbedStatusText" Text="Checking" Foreground="{StaticResource Muted}" Margin="0,6,0,0" /></StackPanel></Border>
                                <Border Style="{StaticResource Card}" Margin="8,0,0,0"><StackPanel><TextBlock Text="Gemma3" Foreground="{StaticResource Ink}" FontWeight="SemiBold" /><TextBlock x:Name="GemmaStatusText" Text="Local model" Foreground="{StaticResource Muted}" Margin="0,6,0,0" /></StackPanel></Border>
                            </UniformGrid>

                            <UniformGrid Columns="6" Margin="0,0,0,14">
                                <Border Style="{StaticResource Card}" Margin="0,0,8,0"><StackPanel><TextBlock Text="Scanned Files" Style="{StaticResource Label}" /><TextBlock x:Name="ScannedFilesText" Text="0" Foreground="{StaticResource Ink}" FontSize="24" Margin="0,10,0,0" /></StackPanel></Border>
                                <Border Style="{StaticResource Card}" Margin="8,0"><StackPanel><TextBlock Text="Indexed Files" Style="{StaticResource Label}" /><TextBlock x:Name="IndexedFilesText" Text="0" Foreground="{StaticResource Ink}" FontSize="24" Margin="0,10,0,0" /></StackPanel></Border>
                                <Border Style="{StaticResource Card}" Margin="8,0"><StackPanel><TextBlock Text="Total Chunks" Style="{StaticResource Label}" /><TextBlock x:Name="ChunkCountText" Text="0" Foreground="{StaticResource Ink}" FontSize="24" Margin="0,10,0,0" /></StackPanel></Border>
                                <Border Style="{StaticResource Card}" Margin="8,0"><StackPanel><TextBlock Text="Total Vectors" Style="{StaticResource Label}" /><TextBlock x:Name="VectorCountText" Text="0" Foreground="{StaticResource Ink}" FontSize="24" Margin="0,10,0,0" /></StackPanel></Border>
                                <Border Style="{StaticResource Card}" Margin="8,0"><StackPanel><TextBlock Text="Last Indexed" Style="{StaticResource Label}" /><TextBlock x:Name="LastIndexedText" Text="Never" Foreground="{StaticResource Ink}" FontSize="14" Margin="0,12,0,0" TextWrapping="Wrap" /></StackPanel></Border>
                                <Border Style="{StaticResource Card}" Margin="8,0,0,0"><StackPanel><TextBlock Text="Current Mode" Style="{StaticResource Label}" /><TextBlock x:Name="CurrentModeText" Text="No brain" Foreground="{StaticResource Ink}" FontSize="16" Margin="0,12,0,0" TextWrapping="Wrap" /></StackPanel></Border>
                            </UniformGrid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Project Brain Build Progress" Foreground="{StaticResource Ink}" FontSize="17" FontWeight="SemiBold" />
                                        <TextBlock x:Name="BuildStatusText" Text="No active indexing" Foreground="{StaticResource Muted}" Margin="0,6,0,12" />
                                        <ProgressBar x:Name="BuildProgressBar" Height="12" Minimum="0" Maximum="100" Value="0" Foreground="{StaticResource Blue}" Background="#202A36" />
                                        <UniformGrid Columns="4" Margin="0,14,0,0">
                                            <StackPanel><TextBlock Text="Files Processed" Style="{StaticResource Label}" /><TextBlock x:Name="FilesProcessedText" Text="0" Foreground="{StaticResource Ink}" Margin="0,6,0,0" /></StackPanel>
                                            <StackPanel><TextBlock Text="Chunks Created" Style="{StaticResource Label}" /><TextBlock x:Name="ChunksCreatedText" Text="0" Foreground="{StaticResource Ink}" Margin="0,6,0,0" /></StackPanel>
                                            <StackPanel><TextBlock Text="Vectors Upserted" Style="{StaticResource Label}" /><TextBlock x:Name="VectorsUpsertedText" Text="0" Foreground="{StaticResource Ink}" Margin="0,6,0,0" /></StackPanel>
                                            <StackPanel><TextBlock Text="Estimated Completion" Style="{StaticResource Label}" /><TextBlock Text="No active indexing" Foreground="{StaticResource Ink}" Margin="0,6,0,0" /></StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Latency Goals" Foreground="{StaticResource Ink}" FontSize="17" FontWeight="SemiBold" />
                                        <TextBlock Text="Prompt optimization target: 0.5-3 seconds" Foreground="{StaticResource Muted}" Margin="0,12,0,0" />
                                        <TextBlock Text="Live autocorrect target: under 80 ms" Foreground="{StaticResource Muted}" Margin="0,8,0,0" />
                                        <TextBlock Text="No latency samples yet" Foreground="{StaticResource Warn}" Margin="0,18,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Recent Optimized Prompts" Foreground="{StaticResource Ink}" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10" />
                                        <ListView x:Name="RecentPromptsList" MinHeight="180" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Indexing Activity" Foreground="{StaticResource Ink}" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10" />
                                        <ListView x:Name="IndexActivityList" MinHeight="180" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Diagnostics" Foreground="{StaticResource Ink}" FontSize="17" FontWeight="SemiBold" />
                                        <TextBlock x:Name="DiagnosticsText" Text="Diagnostics not run yet." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Test FastEmbed" Style="{StaticResource SecondaryButton}" Click="TestFastEmbed_OnClick" Margin="12,0,8,0" />
                                    <Button Grid.Column="2" Content="Test Qdrant" Style="{StaticResource SecondaryButton}" Click="TestQdrant_OnClick" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="BrainPage" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="340" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                            <DockPanel>
                                <Button DockPanel.Dock="Bottom" Content="Open in File Explorer" Style="{StaticResource SecondaryButton}" Click="OpenExplorer_OnClick" Margin="0,12,0,0" />
                                <StackPanel>
                                    <TextBlock Text="Project Explorer" Foreground="{StaticResource Ink}" FontSize="17" FontWeight="SemiBold" />
                                    <TextBlock x:Name="ExplorerPathText" Text="No folder selected" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,12" />
                                    <TreeView x:Name="ProjectTree" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Ink}" Height="520" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <DockPanel>
                                <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,14,0,0">
                                    <UniformGrid Columns="4">
                                        <StackPanel><TextBlock Text="Retrieval Mode" Style="{StaticResource Label}" /><TextBlock x:Name="BrainRetrievalModeText" Text="No brain" Foreground="{StaticResource Ink}" Margin="0,6,0,0" /></StackPanel>
                                        <StackPanel><TextBlock Text="Top Linked Files" Style="{StaticResource Label}" /><TextBlock x:Name="TopLinkedFilesText" Text="No retrieval yet" Foreground="{StaticResource Ink}" Margin="0,6,0,0" TextWrapping="Wrap" /></StackPanel>
                                        <StackPanel><TextBlock Text="Brain Status" Style="{StaticResource Label}" /><TextBlock x:Name="BrainStatusText" Text="No folder" Foreground="{StaticResource Ink}" Margin="0,6,0,0" /></StackPanel>
                                        <StackPanel><TextBlock Text="Vectors" Style="{StaticResource Label}" /><TextBlock x:Name="BrainVectorCountText" Text="0" Foreground="{StaticResource Ink}" Margin="0,6,0,0" /></StackPanel>
                                    </UniformGrid>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="Brain / Knowledge Graph" Foreground="{StaticResource Ink}" FontSize="17" FontWeight="SemiBold" />
                                    <TextBlock Text="Real indexed files and graph nodes. Full visual projection comes later." Foreground="{StaticResource Muted}" Margin="0,6,0,14" />
                                    <ItemsControl x:Name="KnowledgeGraphItems">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#182334" BorderBrush="#34517A" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,10,10" Width="210">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}" Foreground="{StaticResource Ink}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Meta}" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Prompt Compiler" Foreground="{StaticResource Ink}" FontSize="17" FontWeight="SemiBold" />
                                <TextBlock Text="Original Prompt" Foreground="{StaticResource Muted}" Margin="0,18,0,6" />
                                <TextBox x:Name="OriginalPromptBox" Height="130" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                                <TextBlock Text="Optimized Prompt" Foreground="{StaticResource Muted}" Margin="0,18,0,6" />
                                <TextBox x:Name="OptimizedPromptBox" Height="180" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button Content="Fix Prompt" Style="{StaticResource PrimaryButton}" Click="FixPrompt_OnClick" Width="150" />
                                    <Button Content="Copy" Style="{StaticResource SecondaryButton}" Click="CopyPrompt_OnClick" Margin="10,0,0,0" Width="90" />
                                </StackPanel>
                                <TextBlock x:Name="CompilerModeText" Text="No prompt optimized yet" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,18,0,8" />
                                <ListView x:Name="CompilerFilesList" Height="145" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="VectorPage" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                            <UniformGrid Columns="6">
                                <StackPanel><TextBlock Text="Vector DB Status" Style="{StaticResource Label}" /><TextBlock x:Name="VectorDbStatusText" Text="Checking" Foreground="{StaticResource Ink}" Margin="0,8,0,0" /></StackPanel>
                                <StackPanel><TextBlock Text="URL" Style="{StaticResource Label}" /><TextBlock x:Name="VectorUrlText" Text="http://localhost:6333" Foreground="{StaticResource Ink}" Margin="0,8,0,0" TextWrapping="Wrap" /></StackPanel>
                                <StackPanel><TextBlock Text="Collection" Style="{StaticResource Label}" /><TextBlock x:Name="CollectionText" Text="No collection" Foreground="{StaticResource Ink}" Margin="0,8,0,0" TextWrapping="Wrap" /></StackPanel>
                                <StackPanel><TextBlock Text="Embedding Model" Style="{StaticResource Label}" /><TextBlock x:Name="EmbeddingModelText" Text="BAAI/bge-small-en-v1.5" Foreground="{StaticResource Ink}" Margin="0,8,0,0" TextWrapping="Wrap" /></StackPanel>
                                <StackPanel><TextBlock Text="Vector Dimension" Style="{StaticResource Label}" /><TextBlock x:Name="VectorDimensionText" Text="384" Foreground="{StaticResource Ink}" Margin="0,8,0,0" /></StackPanel>
                                <StackPanel><TextBlock Text="Total Vectors / Chunks" Style="{StaticResource Label}" /><TextBlock x:Name="VectorTotalsText" Text="0 / 0" Foreground="{StaticResource Ink}" Margin="0,8,0,0" /></StackPanel>
                            </UniformGrid>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,14">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="Retrieve" Foreground="{StaticResource Ink}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <Button DockPanel.Dock="Right" Content="Search" Style="{StaticResource PrimaryButton}" Click="VectorSearch_OnClick" Margin="10,0,0,0" />
                                <ComboBox x:Name="TopKBox" DockPanel.Dock="Right" Width="72" Height="34" SelectedIndex="1" Margin="10,0,0,0">
                                    <ComboBoxItem Content="5" />
                                    <ComboBoxItem Content="10" />
                                    <ComboBoxItem Content="12" />
                                    <ComboBoxItem Content="20" />
                                </ComboBox>
                                <Button DockPanel.Dock="Right" Content="Filters" Style="{StaticResource SecondaryButton}" />
                                <TextBox x:Name="VectorQueryBox" Height="34" Text="login bug" VerticalContentAlignment="Center" />
                            </DockPanel>
                        </Border>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.3*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Search Results" Foreground="{StaticResource Ink}" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <ListView x:Name="VectorResultsList" SelectionChanged="VectorResultsList_OnSelectionChanged" Height="430" />
                                </StackPanel>
                            </Border>
                            <StackPanel Grid.Column="1">
                                <Border Style="{StaticResource Card}" Margin="8,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Selected Chunk Details" Foreground="{StaticResource Ink}" FontSize="17" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedChunkMetaText" Text="Select a retrieval result." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,10,0,10" />
                                        <TextBox x:Name="SelectedChunkPreviewBox" Height="190" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Vector Space" Foreground="{StaticResource Ink}" FontSize="17" FontWeight="SemiBold" />
                                        <TextBlock Text="Vector projection not generated yet" Foreground="{StaticResource Warn}" Margin="0,10,0,8" />
                                        <TextBlock Text="Estimated clusters: auth, ui, database, docs" Foreground="{StaticResource Muted}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                        <TextBlock Grid.Row="3" x:Name="VectorFooterText" Text="No collection loaded" Foreground="{StaticResource Muted}" Margin="0,14,0,0" />
                    </Grid>

                    <Grid x:Name="PlaceholderPage" Visibility="Collapsed">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock x:Name="PlaceholderTitle" Text="Page" Foreground="{StaticResource Ink}" FontSize="22" FontWeight="SemiBold" />
                                <TextBlock x:Name="PlaceholderText" Text="This page is not built yet." Foreground="{StaticResource Muted}" Margin="0,10,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
