<Window x:Class="Autocorrect.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Global Autocorrect"
        Height="680"
        Width="880"
        MinHeight="620"
        MinWidth="760"
        Background="#F5F7FA"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#182230" />
        <SolidColorBrush x:Key="Muted" Color="#667085" />
        <SolidColorBrush x:Key="Panel" Color="#FFFFFF" />
        <SolidColorBrush x:Key="Line" Color="#D0D5DD" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="BorderBrush" Value="#E4E7EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Global Autocorrect"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="Personal global autocorrect with live suggestions and local learning."
                           Foreground="{StaticResource Muted}"
                           Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="EnabledCheckBox" Content="Running" FontSize="15" Margin="0,0,12,0" />
                <CheckBox x:Name="AutocorrectEnabledCheckBox" Content="Autocorrect" FontSize="15" Margin="0,0,12,0" />
                <CheckBox x:Name="AiOverlayEnabledCheckBox" Content="AI overlay" FontSize="15" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Live status" FontSize="16" FontWeight="SemiBold" />
                        <UniformGrid Columns="2" Margin="0,14,0,0">
                            <StackPanel Margin="0,0,10,12">
                                <TextBlock Text="Inputs" Style="{StaticResource MetricLabel}" />
                                <TextBlock x:Name="InputEventsValue" Text="0" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Fixes" Style="{StaticResource MetricLabel}" />
                                <TextBlock x:Name="CorrectionsValue" Text="0" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="Slow skips" Style="{StaticResource MetricLabel}" />
                                <TextBlock x:Name="SlowSkipsValue" Text="0" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Errors" Style="{StaticResource MetricLabel}" />
                                <TextBlock x:Name="ErrorsValue" Text="0" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                        </UniformGrid>
                        <TextBlock x:Name="LastErrorText"
                                   Foreground="#B42318"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorder}">
                    <StackPanel>
                        <TextBlock Text="Speed" FontSize="16" FontWeight="SemiBold" />
                <TextBlock Text="The keyboard hook never waits. This limit prevents late replacements after you keep typing."
                                   Foreground="{StaticResource Muted}"
                                   Margin="0,4,0,14" />
                        <TextBlock x:Name="MaxLatencyValue" Margin="0,14,0,0" />
                        <Slider x:Name="MaxLatencySlider"
                                Minimum="80"
                                Maximum="1200"
                                TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                ValueChanged="MaxLatencySlider_OnValueChanged" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <TabControl Grid.Column="1"
                        TabStripPlacement="Left">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="MinWidth" Value="132" />
                        <Setter Property="MinHeight" Value="38" />
                        <Setter Property="Padding" Value="12,8" />
                        <Setter Property="Margin" Value="0,0,8,6" />
                        <Setter Property="FontSize" Value="13" />
                    </Style>
                </TabControl.Resources>
                <TabItem Header="Engine">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="14">
                            <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Local spelling engine"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Uses a bundled English frequency dictionary and a SymSpell-style delete index. It is designed for real-time typing and does not call Ollama or Python."
                                               Foreground="{StaticResource Muted}"
                                               Margin="0,8,0,16" />
                                    <TextBlock x:Name="ThresholdValue" />
                                    <Slider x:Name="ThresholdSlider"
                                            Minimum="0.70"
                                            Maximum="0.99"
                                            TickFrequency="0.01"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="ThresholdSlider_OnValueChanged" />
                                    <Separator Margin="0,18,0,18" />
                                    <CheckBox x:Name="ShowSuggestionPopupCheckBox"
                                              Content="Show floating suggestions while typing"
                                              FontSize="15" />
                                    <TextBlock Text="Suggestions appear near the text cursor and can be clicked to replace the current word."
                                               Foreground="{StaticResource Muted}"
                                               Margin="0,8,0,0" />
                                    <Separator Margin="0,18,0,18" />
                                    <CheckBox x:Name="EnableLearningCheckBox"
                                              Content="Learn personal words from my typing"
                                              FontSize="15" />
                                    <TextBlock Text="Repeated words become trusted vocabulary and can win correction ranking."
                                               Foreground="{StaticResource Muted}"
                                               Margin="0,8,0,12" />
                                    <TextBlock x:Name="LearnAfterValue" />
                                    <Slider x:Name="LearnAfterSlider"
                                            Minimum="1"
                                            Maximum="10"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="LearnAfterSlider_OnValueChanged" />
                                    <TextBlock x:Name="LearnedWordsValue"
                                               Foreground="{StaticResource Muted}"
                                               Margin="0,8,0,0" />
                                    <Separator Margin="0,18,0,18" />
                                    <CheckBox x:Name="EnableOnnxCheckBox"
                                              Content="Enable ONNX fallback when a trained model is added"
                                              FontSize="15" />
                                    <TextBlock Text="This is off by default. ONNX is the future upgrade slot, not required for fast v1 correction."
                                               Foreground="{StaticResource Muted}"
                                               Margin="0,8,0,12" />
                                    <TextBlock Text="ONNX model path" />
                                    <TextBox x:Name="OnnxModelPathTextBox" Margin="0,4,0,0" />
                                    <Separator Margin="0,18,0,18" />
                                    <CheckBox x:Name="UseClipboardFallbackCheckBox"
                                              Content="Allow clipboard paste fallback"
                                              FontSize="15" />
                                    <TextBlock Text="Off by default so corrections do not unexpectedly replace your clipboard."
                                               Foreground="{StaticResource Muted}"
                                               Margin="0,8,0,0" />
                                    <Separator Margin="0,18,0,18" />
                                    <CheckBox x:Name="DeveloperModeCheckBox"
                                              Content="Developer mode: allow code editors"
                                              FontSize="15" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Safety">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Blocked apps"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <TextBox x:Name="BlockedProcessesTextBox"
                                 Grid.Row="1"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" />
                    </Grid>
                </TabItem>

                <TabItem Header="AI overlay">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="14">
                            <Border Style="{StaticResource PanelBorder}">
                                <StackPanel>
                                    <CheckBox x:Name="ShowFloatingPillCheckBox"
                                              Content="Show Improve pill"
                                              FontSize="15" />
                                    <TextBlock Text="The pill appears only after a pause and only in allowed text contexts."
                                               Foreground="{StaticResource Muted}"
                                               Margin="0,8,0,14" />
                                    <TextBlock Text="AI provider" />
                                    <ComboBox x:Name="AiProviderComboBox" Margin="0,4,0,12">
                                        <ComboBoxItem Content="local" />
                                        <ComboBoxItem Content="disabled" />
                                        <ComboBoxItem Content="openai-compatible" />
                                    </ComboBox>
                                    <CheckBox x:Name="LocalOnlyModeCheckBox"
                                              Content="Local-only mode"
                                              FontSize="15"
                                              Margin="0,0,0,12" />
                                    <TextBlock Text="Endpoint" />
                                    <TextBox x:Name="AiEndpointTextBox" Margin="0,4,0,12" />
                                    <TextBlock x:Name="FloatingDelayValue" />
                                    <Slider x:Name="FloatingDelaySlider"
                                            Minimum="300"
                                            Maximum="2500"
                                            TickFrequency="100"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="FloatingDelaySlider_OnValueChanged" />
                                    <TextBlock x:Name="MinWordsValue" Margin="0,14,0,0" />
                                    <Slider x:Name="MinWordsSlider"
                                            Minimum="3"
                                            Maximum="40"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="MinWordsSlider_OnValueChanged" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Custom fixes">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="One correction per line: typo=replacement"
                                   Foreground="{StaticResource Muted}"
                                   Margin="0,0,0,8" />
                        <TextBox x:Name="CustomCorrectionsTextBox"
                                 Grid.Row="1"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" />
                    </Grid>
                </TabItem>

                <TabItem Header="Ignored words">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="One word per line. These words will never be corrected."
                                   Foreground="{StaticResource Muted}"
                                   Margin="0,0,0,8" />
                        <TextBox x:Name="IgnoredWordsTextBox"
                                 Grid.Row="1"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" />
                    </Grid>
                </TabItem>

                <TabItem Header="Protected">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Words and product names that should never be autocorrected."
                                   Foreground="{StaticResource Muted}"
                                   Margin="0,0,0,8" />
                        <TextBox x:Name="ProtectedVocabularyTextBox"
                                 Grid.Row="1"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" />
                    </Grid>
                </TabItem>

                <TabItem Header="Learned words">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Highest-count personal words. Edit carefully; each line is word=count."
                                   Foreground="{StaticResource Muted}"
                                   Margin="0,0,0,8" />
                        <Button Content="Clear learned data"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,8"
                                Click="ClearLearned_OnClick" />
                        <TextBox x:Name="LearnedWordsTextBox"
                                 Grid.Row="1"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Refresh"
                    Margin="0,0,8,0"
                    Click="Refresh_OnClick" />
            <Button Content="Cancel"
                    Margin="0,0,8,0"
                    Click="Cancel_OnClick" />
            <Button Content="Save"
                    IsDefault="True"
                    Click="Save_OnClick" />
        </StackPanel>
    </Grid>
</Window>
