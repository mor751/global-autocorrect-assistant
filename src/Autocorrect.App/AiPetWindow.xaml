<Window x:Class="Autocorrect.App.AiPetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="124"
        Height="156"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True">
    <Window.Resources>
        <DropShadowEffect x:Key="CyanGlow" Color="#22D3EE" BlurRadius="26" ShadowDepth="0" Opacity="0.8" />
        <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="32" ShadowDepth="0" Opacity="0.55" />

        <Style x:Key="PrimaryAction" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="46" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#04121A" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="11" BorderThickness="1" BorderBrush="#22D3EE">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#67E8F9" Offset="0" />
                                    <GradientStop Color="#22D3EE" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Effect" Value="{StaticResource CyanGlow}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryAction" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="#CDEBF5" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="9"
                                Background="#101921"
                                BorderBrush="#1F2F3A"
                                BorderThickness="1"
                                Padding="11,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#13242E" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#22D3EE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostAction" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#7C93A3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Background="Transparent" Padding="8,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F1A22" />
                                <Setter Property="Foreground" Value="#A5F3FC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="PetRoot"
          Cursor="Hand"
          MouseLeftButtonDown="PetRoot_OnMouseLeftButtonDown"
          MouseMove="PetRoot_OnMouseMove"
          MouseLeftButtonUp="PetRoot_OnMouseLeftButtonUp">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="AntennaTip" Storyboard.TargetProperty="Opacity"
                                         From="0.5" To="1" Duration="0:0:1.1" AutoReverse="True" RepeatBehavior="Forever" />
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="EyesScale" Storyboard.TargetProperty="ScaleY"
                                                       RepeatBehavior="Forever">
                            <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0" />
                            <LinearDoubleKeyFrame Value="1" KeyTime="0:0:3.4" />
                            <LinearDoubleKeyFrame Value="0.1" KeyTime="0:0:3.5" />
                            <LinearDoubleKeyFrame Value="1" KeyTime="0:0:3.6" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Popup x:Name="ActionsPopup"
               PlacementTarget="{Binding ElementName=PetRoot}"
               Placement="Left"
               HorizontalOffset="-14"
               VerticalOffset="-40"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Width="296"
                    Margin="18"
                    CornerRadius="18"
                    Background="#0A1015"
                    BorderBrush="#1C2C36"
                    BorderThickness="1"
                    Effect="{StaticResource CardShadow}">
                <StackPanel Margin="16">
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,2">
                        <Ellipse Width="9" Height="9" Fill="#22D3EE" VerticalAlignment="Center" Effect="{StaticResource CyanGlow}" />
                        <TextBlock x:Name="PopupTitle"
                                   Text="Beaver"
                                   Foreground="#E5F9FF"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="9,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Quick actions for your selected text"
                               Foreground="#5E768A"
                               FontSize="11.5"
                               Margin="2,0,0,14" />

                    <Button Style="{StaticResource PrimaryAction}" Tag="SmartOptimize" Click="Action_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2728;" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <StackPanel>
                                <TextBlock Text="Improve &amp; compress" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="Fix typos, sharpen wording, fewer tokens" FontSize="10.5" Opacity="0.75" />
                            </StackPanel>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="Ctrl + Alt + O"
                               Foreground="#4A6173"
                               FontSize="10.5"
                               HorizontalAlignment="Right"
                               Margin="0,6,2,0" />

                    <TextBlock Text="MORE"
                               Foreground="#3F5566"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="2,14,0,8" />
                    <UniformGrid Columns="2">
                        <Button Style="{StaticResource SecondaryAction}" Content="Fix typos" Tag="FixTyposOnly" Click="Action_OnClick" Margin="0,0,4,8" />
                        <Button Style="{StaticResource SecondaryAction}" Content="Make direct" Tag="MakeDirect" Click="Action_OnClick" Margin="4,0,0,8" />
                        <Button Style="{StaticResource SecondaryAction}" Content="Professional" Tag="MakeProfessional" Click="Action_OnClick" Margin="0,0,4,0" />
                        <Button Style="{StaticResource SecondaryAction}" Content="Coding prompt" Tag="CursorCodingPrompt" Click="Action_OnClick" Margin="4,0,0,0" />
                    </UniformGrid>
                    <Button Style="{StaticResource SecondaryAction}" Content="Video prompt" Tag="VideoGenerationPrompt" Click="Action_OnClick" Margin="0,8,0,0" />

                    <Border Height="1" Background="#16242E" Margin="0,14,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource GhostAction}" Content="Token dashboard" Click="Dashboard_OnClick" Margin="0,0,4,0" />
                        <Button Grid.Column="1" Style="{StaticResource GhostAction}" Content="Set pet image" Click="SetImage_OnClick" Margin="4,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Popup>

        <Grid x:Name="PetContent">
            <Image x:Name="PetImage"
                   Stretch="Uniform"
                   Visibility="Collapsed"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <Viewbox x:Name="RobotVisual" Stretch="Uniform" Margin="6">
                <Canvas Width="124" Height="156">
                    <Line X1="62" Y1="42" X2="62" Y2="24" Stroke="#22D3EE" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    <Ellipse x:Name="AntennaTip" Canvas.Left="55" Canvas.Top="12" Width="14" Height="14" Fill="#67E8F9" Effect="{StaticResource CyanGlow}" />

                    <Ellipse Canvas.Left="6" Canvas.Top="62" Width="16" Height="30" Fill="#0A0F14" Stroke="#22D3EE" StrokeThickness="2" />
                    <Ellipse Canvas.Left="102" Canvas.Top="62" Width="16" Height="30" Fill="#0A0F14" Stroke="#22D3EE" StrokeThickness="2" />

                    <Border Canvas.Left="24"
                            Canvas.Top="42"
                            Width="76"
                            Height="74"
                            CornerRadius="26"
                            BorderBrush="#22D3EE"
                            BorderThickness="2"
                            Effect="{StaticResource CyanGlow}">
                        <Border.Background>
                            <RadialGradientBrush GradientOrigin="0.5,0.3" Center="0.5,0.4" RadiusX="0.85" RadiusY="0.9">
                                <GradientStop Color="#10566B" Offset="0" />
                                <GradientStop Color="#0A1A22" Offset="0.65" />
                                <GradientStop Color="#070E13" Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel x:Name="EyesGroup"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Margin="0,18,0,0"
                                        RenderTransformOrigin="0.5,0.5">
                                <StackPanel.RenderTransform>
                                    <ScaleTransform x:Name="EyesScale" ScaleX="1" ScaleY="1" />
                                </StackPanel.RenderTransform>
                                <Grid Margin="0,0,9,0">
                                    <Ellipse Width="14" Height="18" Fill="#67E8F9" Effect="{StaticResource CyanGlow}" />
                                    <Ellipse Width="4" Height="5" Fill="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0" />
                                </Grid>
                                <Grid Margin="9,0,0,0">
                                    <Ellipse Width="14" Height="18" Fill="#67E8F9" Effect="{StaticResource CyanGlow}" />
                                    <Ellipse Width="4" Height="5" Fill="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0" />
                                </Grid>
                            </StackPanel>

                            <Path Stroke="#22D3EE"
                                  StrokeThickness="2.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,0,15"
                                  Data="M 0,0 Q 10,9 20,0" />
                        </Grid>
                    </Border>

                    <Border Canvas.Left="40"
                            Canvas.Top="120"
                            Width="44"
                            Height="22"
                            CornerRadius="11"
                            Background="#0B1622"
                            BorderBrush="#22D3EE"
                            BorderThickness="1">
                        <TextBlock x:Name="BadgeText"
                                   Text="AI"
                                   Foreground="#A5F3FC"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </Canvas>
            </Viewbox>
        </Grid>
    </Grid>
</Window>
