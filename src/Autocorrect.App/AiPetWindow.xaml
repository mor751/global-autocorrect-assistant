<Window x:Class="Autocorrect.App.AiPetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="124"
        Height="156"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True">
    <Window.Resources>
        <DropShadowEffect x:Key="WarmGlow" Color="#FDBA74" BlurRadius="24" ShadowDepth="0" Opacity="0.72" />
        <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="32" ShadowDepth="0" Opacity="0.55" />

        <Style x:Key="PrimaryAction" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="46" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#04121A" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="11" BorderThickness="1" BorderBrush="#FDBA74">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FED7AA" Offset="0" />
                                    <GradientStop Color="#FDBA74" Offset="0.55" />
                                    <GradientStop Color="#FB923C" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Effect" Value="{StaticResource WarmGlow}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryAction" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="#FFF7ED" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="9"
                                Background="#17110D"
                                BorderBrush="#3B2415"
                                BorderThickness="1"
                                Padding="11,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#24170E" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FDBA74" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostAction" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#7C93A3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Background="Transparent" Padding="8,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#21150D" />
                                <Setter Property="Foreground" Value="#FED7AA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="PetRoot"
          Background="#01000000"
          Cursor="Hand"
          PreviewMouseLeftButtonDown="PetRoot_OnMouseLeftButtonDown"
          PreviewMouseMove="PetRoot_OnMouseMove"
          PreviewMouseLeftButtonUp="PetRoot_OnMouseLeftButtonUp">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="AntennaTip" Storyboard.TargetProperty="Opacity"
                                         From="0.5" To="1" Duration="0:0:1.1" AutoReverse="True" RepeatBehavior="Forever" />
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="EyesScale" Storyboard.TargetProperty="ScaleY"
                                                       RepeatBehavior="Forever">
                            <LinearDoubleKeyFrame Value="1" KeyTime="0:0:0" />
                            <LinearDoubleKeyFrame Value="1" KeyTime="0:0:3.4" />
                            <LinearDoubleKeyFrame Value="0.1" KeyTime="0:0:3.5" />
                            <LinearDoubleKeyFrame Value="1" KeyTime="0:0:3.6" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Popup x:Name="ActionsPopup"
               PlacementTarget="{Binding ElementName=PetRoot}"
               Placement="Left"
               HorizontalOffset="-14"
               VerticalOffset="-40"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border x:Name="ActionsPopupCard"
                    Width="310"
                    Margin="18"
                    CornerRadius="18"
                    Background="#100D0A"
                    BorderBrush="#3A271B"
                    BorderThickness="1"
                    Effect="{StaticResource CardShadow}">
                <StackPanel Margin="16">
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,2">
                        <Ellipse Width="9" Height="9" Fill="#FDBA74" VerticalAlignment="Center" Effect="{StaticResource WarmGlow}" />
                        <TextBlock x:Name="PopupTitle"
                                   Text="Beaver"
                                   Foreground="#FFF7ED"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="9,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Project-aware prompt compiler"
                               Foreground="#A58A72"
                               FontSize="11.5"
                               Margin="2,0,0,10" />

                    <Border Background="#15100C"
                            BorderBrush="#3A271B"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,8"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="WORKING FOLDER"
                                       Foreground="#8A6A50"
                                       FontSize="10"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="ProjectPathText"
                                       Text="No project folder selected"
                                       Foreground="#FFF7ED"
                                       FontSize="11.5"
                                       TextWrapping="Wrap"
                                       Margin="0,3,0,0"
                                       MaxHeight="44" />
                            <TextBlock x:Name="ProjectStatusText"
                                       Text="Choose a folder to build Woody's local project brain."
                                       Foreground="#B08A6E"
                                       FontSize="10.5"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Button Style="{StaticResource PrimaryAction}" Click="FixPrompt_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2728;" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <StackPanel>
                                <TextBlock Text="Fix Prompt" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="Clean, compress, and add project context" FontSize="10.5" Opacity="0.75" />
                            </StackPanel>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="Ctrl + Alt + O"
                               Foreground="#8A6A50"
                               FontSize="10.5"
                               HorizontalAlignment="Right"
                               Margin="0,6,2,0" />

                    <TextBlock Text="PROJECT"
                               Foreground="#8A6A50"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="2,14,0,8" />
                    <UniformGrid Columns="2">
                        <Button Style="{StaticResource SecondaryAction}" Content="Choose Folder" Click="ChooseFolder_OnClick" Margin="0,0,4,8" />
                        <Button Style="{StaticResource SecondaryAction}" Content="View RAG" Click="ViewRag_OnClick" Margin="4,0,0,8" />
                        <Button Style="{StaticResource SecondaryAction}" Content="View Dashboard" Click="Dashboard_OnClick" Margin="0,0,4,8" />
                        <Button Style="{StaticResource SecondaryAction}" Content="Reindex Project" Click="Reindex_OnClick" Margin="4,0,0,8" />
                        <Button Style="{StaticResource SecondaryAction}" Content="Qdrant Status" Click="QdrantStatus_OnClick" Margin="0,0,4,0" />
                        <Button Style="{StaticResource SecondaryAction}" Content="Set pet image" Click="SetImage_OnClick" Margin="4,0,0,0" />
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Popup>

        <Grid x:Name="PetContent">
            <Image x:Name="PetImage"
                   Stretch="Uniform"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <Viewbox x:Name="RobotVisual" Stretch="Uniform" Margin="6" IsHitTestVisible="False">
                <Canvas Width="124" Height="156">
                    <Line X1="62" Y1="42" X2="62" Y2="24" Stroke="#FDBA74" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    <Ellipse x:Name="AntennaTip" Canvas.Left="55" Canvas.Top="12" Width="14" Height="14" Fill="#FDBA74" Effect="{StaticResource WarmGlow}" />

                    <Ellipse Canvas.Left="6" Canvas.Top="62" Width="16" Height="30" Fill="#0A0F14" Stroke="#FDBA74" StrokeThickness="2" />
                    <Ellipse Canvas.Left="102" Canvas.Top="62" Width="16" Height="30" Fill="#0A0F14" Stroke="#FDBA74" StrokeThickness="2" />

                    <Border Canvas.Left="24"
                            Canvas.Top="42"
                            Width="76"
                            Height="74"
                            CornerRadius="26"
                            BorderBrush="#FDBA74"
                            BorderThickness="2"
                            Effect="{StaticResource WarmGlow}">
                        <Border.Background>
                            <RadialGradientBrush GradientOrigin="0.5,0.3" Center="0.5,0.4" RadiusX="0.85" RadiusY="0.9">
                                <GradientStop Color="#6B3510" Offset="0" />
                                <GradientStop Color="#1F130B" Offset="0.65" />
                                <GradientStop Color="#090604" Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel x:Name="EyesGroup"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Margin="0,18,0,0"
                                        RenderTransformOrigin="0.5,0.5">
                                <StackPanel.RenderTransform>
                                    <ScaleTransform x:Name="EyesScale" ScaleX="1" ScaleY="1" />
                                </StackPanel.RenderTransform>
                                <Grid Margin="0,0,9,0">
                                    <Ellipse Width="14" Height="18" Fill="#FDBA74" Effect="{StaticResource WarmGlow}" />
                                    <Ellipse Width="4" Height="5" Fill="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0" />
                                </Grid>
                                <Grid Margin="9,0,0,0">
                                    <Ellipse Width="14" Height="18" Fill="#FDBA74" Effect="{StaticResource WarmGlow}" />
                                    <Ellipse Width="4" Height="5" Fill="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0" />
                                </Grid>
                            </StackPanel>

                            <Path Stroke="#FDBA74"
                                  StrokeThickness="2.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,0,15"
                                  Data="M 0,0 Q 10,9 20,0" />
                        </Grid>
                    </Border>

                    <Border Canvas.Left="40"
                            Canvas.Top="120"
                            Width="44"
                            Height="22"
                            CornerRadius="11"
                            Background="#0B1622"
                            BorderBrush="#FDBA74"
                            BorderThickness="1">
                        <TextBlock x:Name="BadgeText"
                                   Text="AI"
                                   Foreground="#FED7AA"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </Canvas>
            </Viewbox>
        </Grid>
    </Grid>
</Window>
