<Window x:Class="Autocorrect.App.ProjectBrainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project Brain"
        Width="1040"
        Height="760"
        MinWidth="820"
        MinHeight="600"
        Background="#06090D"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#E6EDF3" />
        <SolidColorBrush x:Key="Muted" Color="#7C8B9A" />
        <SolidColorBrush x:Key="Cyan" Color="#22D3EE" />
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#E5F9FF" />
            <Setter Property="Background" Value="#0E2630" />
            <Setter Property="BorderBrush" Value="#22D3EE" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" Foreground="{StaticResource Ink}" FontSize="20" FontWeight="Bold" />
            <TextBlock x:Name="SubtitleText" Foreground="{StaticResource Muted}" FontSize="12.5" Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Background="#080C11" BorderBrush="#13202A" BorderThickness="1" CornerRadius="14">
            <Viewbox Stretch="Uniform" Margin="10">
                <Canvas x:Name="GraphCanvas" Width="1100" Height="760" />
            </Viewbox>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="LegendText" Foreground="{StaticResource Muted}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button x:Name="ReindexButton" Content="Re-index" Click="Reindex_OnClick" />
            <Button Content="Close" Click="Close_OnClick" />
        </StackPanel>
    </Grid>
</Window>
