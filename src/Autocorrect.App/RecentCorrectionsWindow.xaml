<Window x:Class="Autocorrect.App.RecentCorrectionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recent Corrections"
        Height="420"
        Width="720"
        MinHeight="360"
        MinWidth="620"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="CorrectionsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding WhenText}" Width="120" />
                <DataGridTextColumn Header="Original" Binding="{Binding Original}" Width="*" />
                <DataGridTextColumn Header="Replacement" Binding="{Binding Replacement}" Width="*" />
                <DataGridTextColumn Header="Confidence" Binding="{Binding ConfidenceText}" Width="95" />
                <DataGridTextColumn Header="App" Binding="{Binding ProcessName}" Width="120" />
                <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="160" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Refresh"
                    Width="86"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="Refresh_OnClick" />
            <Button Content="Close"
                    Width="86"
                    Height="30"
                    IsCancel="True"
                    Click="Close_OnClick" />
        </StackPanel>
    </Grid>
</Window>
