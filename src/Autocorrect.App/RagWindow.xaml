<Window x:Class="Autocorrect.App.RagWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Woody RAG"
        Width="1060"
        Height="720"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#06090D"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#E6EDF3" />
        <SolidColorBrush x:Key="Muted" Color="#7C8B9A" />
        <SolidColorBrush x:Key="Panel" Color="#0B1118" />
        <SolidColorBrush x:Key="Line" Color="#172432" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#E5F9FF" />
            <Setter Property="Background" Value="#0E2630" />
            <Setter Property="BorderBrush" Value="#22D3EE" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
            <Setter Property="Background" Value="#0F1720" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="CaretBrush" Value="#22D3EE" />
            <Setter Property="Padding" Value="10" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Woody Project RAG"
                       FontSize="22"
                       FontWeight="Bold" />
            <TextBlock x:Name="FolderText"
                       Foreground="{StaticResource Muted}"
                       FontSize="12.5"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Line}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,0,12">
            <UniformGrid Columns="6">
                <StackPanel>
                    <TextBlock Text="STATUS" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusText" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="FILES" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock x:Name="FileCountText" FontSize="18" FontWeight="Bold" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="CHUNKS" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock x:Name="ChunkCountText" FontSize="18" FontWeight="Bold" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="STACK" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock x:Name="StackText" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="LAST INDEX" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock x:Name="IndexedText" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="VECTOR DB" Foreground="{StaticResource Muted}" FontSize="10" FontWeight="SemiBold" />
                    <TextBlock x:Name="VectorDbText" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </UniformGrid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Line}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="180" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Folder tree and indexed files"
                               Foreground="{StaticResource Muted}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <TreeView x:Name="FolderTree"
                              Grid.Row="1"
                              Background="#081018"
                              BorderBrush="{StaticResource Line}"
                              BorderThickness="1"
                              Foreground="{StaticResource Ink}"
                              Margin="0,0,0,10" />
                    <ListView x:Name="FilesList"
                              Grid.Row="2"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="{StaticResource Ink}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Path}" Foreground="#CDEBF5" FontSize="12.5" />
                                    <TextBlock Text="{Binding Meta}" Foreground="{StaticResource Muted}" FontSize="10.5" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Line}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Retrieval test"
                               Foreground="{StaticResource Muted}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <DockPanel Grid.Row="1" Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right" Content="Search" Click="Search_OnClick" Margin="8,0,0,0" />
                        <TextBox x:Name="SearchBox"
                                 MinHeight="36"
                                 VerticalContentAlignment="Center"
                                 KeyDown="SearchBox_OnKeyDown"
                                 Text="login bug" />
                    </DockPanel>
                    <ListView x:Name="ResultsList"
                              Grid.Row="2"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="{StaticResource Ink}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#081018" BorderBrush="#152433" BorderThickness="1" CornerRadius="9" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Path}" Foreground="#67E8F9" FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="{Binding Reason}" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,3,0,0" />
                                        <TextBlock Text="{Binding Summary}" Foreground="#CDEBF5" FontSize="12" Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Re-index" Click="Reindex_OnClick" />
            <Button Content="Refresh" Click="Refresh_OnClick" />
            <Button Content="Close" Click="Close_OnClick" />
        </StackPanel>
    </Grid>
</Window>
