<Window x:Class="Autocorrect.App.ImproveTextWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Improve text"
        Width="760"
        Height="560"
        MinWidth="680"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Improve text" FontSize="24" FontWeight="SemiBold" />
        <Grid Grid.Row="1" Margin="0,16,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="Original" FontWeight="SemiBold" />
            <TextBox x:Name="OriginalTextBox" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
            <TextBlock Grid.Column="1" Text="Result" FontWeight="SemiBold" Margin="14,0,0,0" />
            <TextBox x:Name="ResultTextBox" Grid.Column="1" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="14,0,0,0" />
            <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,14,0,14">
                <Button Content="Fix typos" Tag="FixTyposOnly" Click="Action_OnClick" Margin="0,0,8,8" />
                <Button Content="Optimize prompt" Tag="OptimizePrompt" Click="Action_OnClick" Margin="0,0,8,8" />
                <Button Content="Compress tokens" Tag="CompressTokens" Click="Action_OnClick" Margin="0,0,8,8" />
                <Button Content="Make clearer" Tag="ImproveClarity" Click="Action_OnClick" Margin="0,0,8,8" />
                <Button Content="Professional" Tag="MakeProfessional" Click="Action_OnClick" Margin="0,0,8,8" />
                <Button Content="Direct" Tag="MakeDirect" Click="Action_OnClick" Margin="0,0,8,8" />
                <Button Content="Cursor prompt" Tag="CursorCodingPrompt" Click="Action_OnClick" Margin="0,0,8,8" />
                <Button Content="Video prompt" Tag="VideoGenerationPrompt" Click="Action_OnClick" Margin="0,0,8,8" />
            </WrapPanel>
            <TextBlock x:Name="ExplanationText" Grid.Row="3" Grid.ColumnSpan="2" Foreground="#475569" TextWrapping="Wrap" />
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Replace" Click="Replace_OnClick" Margin="0,0,8,0" />
            <Button Content="Copy" Click="Copy_OnClick" Margin="0,0,8,0" />
            <Button Content="Try shorter" Tag="CompressTokens" Click="Action_OnClick" Margin="0,0,8,0" />
            <Button Content="Try detailed" Tag="ImproveClarity" Click="Action_OnClick" Margin="0,0,8,0" />
            <Button Content="Cancel" Click="Cancel_OnClick" />
        </StackPanel>
    </Grid>
</Window>
